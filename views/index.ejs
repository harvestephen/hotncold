<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" type="text/css" href="/styles/app.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <title>HotnCold - Home</title>
  </head>
  <body>
    <div class="d-flex justify-content-center align-items-center vh-100">
      <div class="row w-100 justify-content-center">
        <div class="col-10 col-sm-8 col-md-6 col-lg-5 col-xl-4">
          <div class="card">
            <div class="card-body text-light">
              <p class="h1">To Do:</p>
              <form action="/add" method="POST">
                <div class="input-group flex-nowrap">
                  <span class="input-group-text" id="addon-wrapping"
                    >Add Task</span
                  >
                  <input
                    type="text"
                    class="form-control"
                    placeholder="ex. Cook Dinner"
                    aria-label="Username"
                    aria-describedby="addon-wrapping"
                    name="item"
                  />
                  <button type="submit" class="btn btn-primary">Add</button>
                </div>
                <br />
                <table
                  class="table table-hover table-striped table-dark"
                  style="position: relative"
                >
                  <thead>
                    <tr>
                      <th scope="col" colspan="4">Tasks</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (Item){ %> <%Item.forEach( function(data){ %>
                    <!-- Modal -->
                    <div
                      class="modal fade"
                      id="staticBackdrop"
                      data-bs-backdrop="static"
                      data-bs-keyboard="false"
                      tabindex="-1"
                      aria-labelledby="staticBackdropLabel"
                      aria-hidden="true"
                    >
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h1
                              class="modal-title fs-5"
                              id="staticBackdropLabel"
                              style="color: black"
                            >
                              Update Tasks
                            </h1>
                          </div>
                          <div class="modal-body">
                            <form>
                            <input
                              id="<%= data.id; %>"
                              name="updateItem"
                              class="hiddenss trig"
                              type="text"
                            />
                          </div>
                          <div class="modal-footer">
                            <button
                              type="button"
                              class="btn btn-secondary"
                              data-bs-dismiss="modal"
                            >
                              Close
                            </button>
                            <button
                              id="<%= data.id; %>"
                              class="hiddenss trig btn btn-success"
                              type="submit"
                              formmethod="POST"
                              formaction="/update/<%= data.id; %>"
                            >
                              Update
                            </button>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>
                    <form action="/<%= data.id; %>">
                      <tr>
                        <td style="vertical-align: middle">
                          <div class="overflow"><%= data.Item; %></div>
                        </td>
                        <td style="text-align: right">
                          <button
                            id="`.toggle-${id}`"
                            class="toggle btn btn-primary"
                            type="button"
                            onclick="showShowables(`<%= data.id; %>`);"
                            data-bs-toggle="modal"
                            data-bs-target="#staticBackdrop"
                          >
                            edit
                          </button>
                          <button
                            class="btn btn-danger"
                            type="submit"
                            formmethod="POST"
                            formaction="/delete/<%= data.id; %>"
                          >
                            delete
                          </button>
                        </td>
                      </tr>
                    </form>
                    <% })} %>
                  </tbody>
                </table>

                <button
                  type="submit"
                  formaction="/logout"
                  class="btn btn-danger"
                >
                  Logout
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/scripts/scripts.js"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
